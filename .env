# ============================================
#       DARKLORD XMD — CONFIGURATION
# ============================================

# YOUR SESSION ID — paste your LordFarhan-XMD~ session here
# Get it from: your deployed pair site
# Format: LordFarhan-XMD~XXXXXXXXXXXXXXXXXXXXXXXX
SESSION_ID=

# Bot mode: public or private
MODE=public

# Timezone — e.g. Africa/Nairobi | Asia/Karachi | America/New_York
TIME_ZONE=Africa/Nairobi

# Auto read WhatsApp statuses: true or false
AUTO_READ_STATUS=true

# Auto like WhatsApp statuses: true or false
AUTO_LIKE_STATUS=true

# PostgreSQL database URL (optional)
# Leave empty to use local SQLite (./gift/session/store.db)
# Free options: neon.tech | supabase.com | render.com
DATABASE_URL=
